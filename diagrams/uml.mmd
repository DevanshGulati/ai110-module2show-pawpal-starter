classDiagram
    %% PawPal+ class diagram. Keep this updated so it matches your final implementation.

    class Owner {
        +str name
        +list~Pet~ pets
        +dict preferences
        +add_pet(pet) void
        +add_task(pet, task) void
        +all_tasks() list~Task~
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task) void
        +remove_task(task) void
    }

    class Task {
        +str description
        +int duration_minutes
        +str priority
        +str time
        +str frequency
        +bool completed
        +mark_complete() void
        +priority_score() int
    }

    class Scheduler {
        +int available_minutes
        +str start_time
        +build_plan(tasks) list~ScheduledItem~
        +explain(plan) str
    }

    class ScheduledItem {
        +Task task
        +str start_time
        +end_minutes() int
        +end_time() str
    }

    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" Task : owns
    Scheduler ..> Task : schedules
    Scheduler ..> ScheduledItem : produces
    ScheduledItem "*" --> "1" Task : wraps
