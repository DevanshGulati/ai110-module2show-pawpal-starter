classDiagram
    %% PawPal+ class diagram. Keep this updated so it matches your final implementation.

    class Owner {
        +str name
        +list~Pet~ pets
        +dict preferences
        +add_pet(pet) void
        +add_task(pet, task) void
    }

    class Pet {
        +str name
        +str species
        +list~CareTask~ tasks
        +add_task(task) void
        +remove_task(task) void
    }

    class CareTask {
        +str title
        +int duration_minutes
        +str priority
        +str preferred_time
        +priority_score() int
    }

    class Scheduler {
        +int available_minutes
        +str start_time
        +build_plan(tasks) list~ScheduledItem~
        +explain(plan) str
    }

    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" CareTask : owns
    Scheduler ..> CareTask : schedules
    Scheduler ..> Pet : plans for
